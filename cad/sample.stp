ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('Sample STEP File'),'2;1');
FILE_NAME('sample.step','2024-01-01',('Sample Author'),('Sample Org'),'','','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN'));
ENDSEC;
DATA;
#1=SHAPE_DEFINITION_REPRESENTATION(#2,#10);
#2=PRODUCT_DEFINITION_SHAPE('','',#3);
#3=PRODUCT_DEFINITION('design','',#4,#5);
#4=PRODUCT_DEFINITION_FORMATION('','',#6);
#5=PRODUCT_DEFINITION_CONTEXT('part definition',#7,'design');
#6=PRODUCT('SampleBox','SampleBox','Sample STEP cube',(#8));
#7=APPLICATION_CONTEXT('core data for automotive mechanical design processes');
#8=PRODUCT_CONTEXT('',#7,'mechanical');
#9=APPLICATION_PROTOCOL_DEFINITION('international standard','automotive_design',2000,#7);
#10=SHAPE_REPRESENTATION('',(#11),#12);
#11=AXIS2_PLACEMENT_3D('',#13,#14,#15);
#12=(GEOMETRIC_REPRESENTATION_CONTEXT(3)GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#16))GLOBAL_UNIT_ASSIGNED_CONTEXT((#17,#18,#19))REPRESENTATION_CONTEXT('Context3D','3D Context with 1e-7 uncertainty'));
#13=CARTESIAN_POINT('',(0.,0.,0.));
#14=DIRECTION('',(0.,0.,1.));
#15=DIRECTION('',(1.,0.,0.));
#16=UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-07),#17,'distance_accuracy_value','confusion accuracy');
#17=(LENGTH_UNIT()NAMED_UNIT(*)SI_UNIT(.MILLI.,.METRE.));
#18=(NAMED_UNIT(*)PLANE_ANGLE_UNIT()SI_UNIT($,.RADIAN.));
#19=(NAMED_UNIT(*)SI_UNIT($,.STERADIAN.)SOLID_ANGLE_UNIT());
ENDSEC;
END-ISO-10303-21;
